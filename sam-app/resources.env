# ──────────────────────────────────────────────────
# Resource names — single source of truth
# All hardcoded resource names in this project derive
# from these variables. Change here, then regenerate
# env.json and samconfig.toml as needed.
#
# Derived from terraform/aws-app/terraform.tfvars:
#   table   =>  {project_name}{env_under}{table_suffix}
#   files   =>  {namespace}-{project_name}{env_dash}{files_bucket_suffix}
#   queue   =>  {project_name}{env_under}{queue_suffix}
#
# Frontend (S3 bucket + CloudFront + OAC) is now managed by
# terraform/aws-frontend/terraform.tfvars:
#   front   =>  {namespace}-{project_name}{env_dash}{front_bucket_suffix}
#   oac     =>  {project_name}{env_dash}{oac_name_suffix}
#
# Current values (environment="" → no suffix):
#   project_name=0shared, namespace=luidsonl
#   table_suffix="", files_bucket_suffix=-files, queue_suffix=_upload
#   front_bucket_suffix=-front, oac_name_suffix=-s3-oac
# ──────────────────────────────────────────────────

# SAM CloudFormation stack name
STACK_NAME=app-0shared-backend

# DynamoDB table name
DYNAMODB_TABLE=0shared

# S3 bucket for user files
FILES_BUCKET=luidsonl-0shared-files

# SQS upload queue (managed by Terraform, referenced by SAM event source mapping)
# Queue name: 0shared_upload
# DLQ name: 0shared_upload_dlq
